# Server Configuration
PORT=5200
NODE_ENV=development

# PostgreSQL Configuration (for Works Management API)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=cecelia
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password_here

# Platform Data API (existing, port 5220)
# This is for the platform-data endpoint

# ToAPI Configuration (Video Generation Service)
# IMPORTANT: This key should NEVER be in frontend code (no VITE_ prefix)
# Store actual key in ~/.credentials/toapi.env or use CI/CD secrets
TOAPI_API_KEY=your_toapi_key_here
