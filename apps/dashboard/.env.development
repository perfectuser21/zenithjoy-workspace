# 开发环境配置

# 跳过飞书登录，使用 mock 用户
VITE_SKIP_AUTH=true

# Mock 用户信息（开发时自动登录）
VITE_MOCK_USER_ID=dev-user-001
VITE_MOCK_USER_NAME=开发者
VITE_MOCK_USER_AVATAR=https://api.dicebear.com/7.x/avataaars/svg?seed=dev

# API 地址（空 = 走 Vite proxy 到本地 N8N）
VITE_API_URL=

# 超级管理员 ID（开发时默认是超级管理员）
VITE_SUPER_ADMIN_FEISHU_IDS=dev-user-001

# Analytics & A/B Testing
# Microsoft Clarity Project ID - Get yours at https://clarity.microsoft.com
VITE_CLARITY_ID=placeholder
