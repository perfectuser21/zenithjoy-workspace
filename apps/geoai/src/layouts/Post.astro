---
// 短内容/帖子布局 - 自适应图片比例
import Base from './Base.astro';
import Comments from '../components/Comments.astro';

interface Props {
  title: string;
  content: string;
  image?: string;
  publishDate: Date;
  author?: string;
  slug?: string;
}

const {
  title,
  content,
  image,
  publishDate,
  author = 'ZenithJoyAI',
  slug,
} = Astro.props;

const locale = Astro.currentLocale || 'zh';
const formattedDate = publishDate.toLocaleDateString(locale === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const contactInfo = {
  wechat: 'zenithjoyai',
  douyin: 'zenithjoyai',
};
---

<Base
  title={title}
  description={content.slice(0, 150)}
  type="article"
  image={image}
  publishDate={publishDate}
>
  <article class="max-w-xl mx-auto px-4 py-8">
    <!-- 主卡片 -->
    <div class="bg-[var(--color-bg-card)] rounded-3xl border border-[var(--color-border)] overflow-hidden shadow-lg">

      <!-- 图片区域 - 自适应比例，限制最大高度 -->
      {image && (
        <div class="relative flex items-center justify-center bg-black/5">
          <img
            src={image}
            alt={title}
            class="w-full h-auto max-h-[70vh] object-contain"
            loading="eager"
          />
        </div>
      )}

      <!-- 内容区域 -->
      <div class="p-6">
        <!-- 作者信息 -->
        <div class="flex items-center gap-3 mb-4">
          <div class="w-11 h-11 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white font-bold shadow-md">
            ZJ
          </div>
          <div>
            <div class="font-semibold text-[var(--color-text)]">{author}</div>
            <div class="text-xs text-[var(--color-text-muted)]">{formattedDate}</div>
          </div>
        </div>

        <!-- 标题 -->
        <h1 class="text-xl font-bold leading-tight mb-4 text-[var(--color-text)]">
          {title}
        </h1>

        <!-- 正文 -->
        <div class="text-[var(--color-text)] leading-relaxed whitespace-pre-line text-[15px]">
          {content}
        </div>
      </div>

      <!-- 底部操作栏 -->
      <div class="px-6 py-4 border-t border-[var(--color-border)] bg-[var(--color-bg)]/50">
        <div class="flex items-center justify-between text-[var(--color-text-muted)]">
          <div class="flex items-center gap-5">
            <button class="flex items-center gap-1.5 hover:text-red-500 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
              <span class="text-sm">喜欢</span>
            </button>
            <button class="flex items-center gap-1.5 hover:text-[var(--color-primary)] transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
              </svg>
              <span class="text-sm">分享</span>
            </button>
          </div>
          <a
            href={`/${locale}/blog`}
            class="text-sm hover:text-[var(--color-primary)] transition-colors"
          >
            更多内容 →
          </a>
        </div>
      </div>
    </div>

    <!-- 关注卡片 -->
    <div class="mt-6 p-5 bg-gradient-to-br from-[var(--color-primary)]/5 to-[var(--color-accent)]/5 rounded-2xl border border-[var(--color-border)]">
      <p class="text-center text-[var(--color-text-muted)] text-sm mb-3">
        {locale === 'zh' ? '关注我获取更多 AI 效率技巧' : 'Follow for more AI tips'}
      </p>
      <div class="flex items-center justify-center gap-4 text-sm">
        <span class="px-3 py-1.5 bg-[var(--color-bg-card)] rounded-full">
          微信: <strong class="text-[var(--color-primary)]">{contactInfo.wechat}</strong>
        </span>
        <span class="px-3 py-1.5 bg-[var(--color-bg-card)] rounded-full">
          抖音: <strong class="text-[var(--color-primary)]">{contactInfo.douyin}</strong>
        </span>
      </div>
    </div>

    <!-- 评论区 -->
    {slug && <Comments slug={slug} locale={locale} />}

    <!-- 返回 -->
    <div class="mt-6 text-center">
      <a
        href={`/${locale}/blog`}
        class="inline-flex items-center gap-2 text-[var(--color-text-muted)] hover:text-[var(--color-primary)] transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
        {locale === 'zh' ? '返回列表' : 'Back'}
      </a>
    </div>
  </article>

  <!-- 阅读计数器 -->
  {slug && (
    <script is:inline data-slug={slug}>
      (function() {
        const slug = document.currentScript.dataset.slug;
        if (slug) {
          fetch(`https://zenithjoyai-page-counter.zenithjoyai.workers.dev?slug=${encodeURIComponent(slug)}`, { method: 'POST' })
            .catch(e => console.error('View counter error:', e));
        }
      })();
    </script>
  )}
</Base>
