---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Schema from '../components/Schema.astro';

interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  image?: string;
  publishDate?: Date;
  faq?: { question: string; answer: string }[];
}

const { title, description, type = 'website', image, publishDate, faq } = Astro.props;
const locale = Astro.currentLocale || 'zh';
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---

<!DOCTYPE html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Preload Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <SEO
      title={title}
      description={description}
      type={type}
      image={image}
      publishDate={publishDate}
      locale={locale === 'zh' ? 'zh-CN' : 'en-US'}
    />

    <Schema
      type={type}
      data={{
        title,
        description,
        publishDate,
        faq
      }}
    />

    <!-- Google Analytics (GA4) — 通过 PUBLIC_GA_MEASUREMENT_ID 环境变量启用 -->
    {GA_MEASUREMENT_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`} is:inline></script>
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID, { anonymize_ip: true });
        </script>
      </>
    )}

    <!-- Theme Detection -->
    <script is:inline>
      const theme = localStorage.getItem('theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.classList.toggle('dark', theme === 'dark');
    </script>
  </head>

  <body class="min-h-screen antialiased">
    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 glass">
      <div class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
        <a href={`/${locale}`} class="text-xl font-bold text-[var(--color-primary)]">
          ZenithJoyAI
        </a>

        <div class="flex items-center gap-6">
          <a href={`/${locale}/videos`} class="hover:text-[var(--color-primary)] transition-colors">
            {locale === 'zh' ? '视频' : 'Videos'}
          </a>
          <a href={`/${locale}/posts`} class="hover:text-[var(--color-primary)] transition-colors">
            {locale === 'zh' ? '动态' : 'Updates'}
          </a>
          <a href={`/${locale}/blog`} class="hover:text-[var(--color-primary)] transition-colors">
            {locale === 'zh' ? '文章' : 'Articles'}
          </a>
          <a href={`/${locale}/services`} class="hover:text-[var(--color-primary)] transition-colors">
            {locale === 'zh' ? '服务' : 'Services'}
          </a>
          <a href={`/${locale}/about`} class="hover:text-[var(--color-primary)] transition-colors">
            {locale === 'zh' ? '关于' : 'About'}
          </a>

          <!-- Language Switcher -->
          <a
            href={locale === 'zh' ? '/en' : '/zh'}
            class="px-3 py-1 rounded-full text-sm border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors"
          >
            {locale === 'zh' ? 'EN' : '中文'}
          </a>

          <!-- Theme Toggle -->
          <button
            id="theme-toggle"
            class="p-2 rounded-full hover:bg-[var(--color-bg-card)] transition-colors"
            aria-label="Toggle theme"
          >
            <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 6.464A1 1 0 106.465 5.05l-.708-.707a1 1 0 00-1.414 1.414l.707.707zm1.414 8.486l-.707.707a1 1 0 01-1.414-1.414l.707-.707a1 1 0 011.414 1.414zM4 11a1 1 0 100-2H3a1 1 0 000 2h1z"/>
            </svg>
            <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 20 20">
              <path d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"/>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="pt-20">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="mt-20 py-12 border-t border-[var(--color-border)]">
      <div class="max-w-6xl mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8 mb-8">
          <!-- Brand -->
          <div>
            <div class="text-xl font-bold text-[var(--color-primary)] mb-3">ZenithJoyAI</div>
            <p class="text-sm text-[var(--color-text-muted)]">
              {locale === 'zh'
                ? '用 AI 赋能创作者，让效率提升 10 倍'
                : 'Empowering creators with AI, 10x your efficiency'
              }
            </p>
          </div>

          <!-- Links -->
          <div>
            <div class="font-medium mb-3">{locale === 'zh' ? '内容' : 'Content'}</div>
            <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
              <a href={`/${locale}/videos`} class="block hover:text-[var(--color-primary)]">{locale === 'zh' ? '视频' : 'Videos'}</a>
              <a href={`/${locale}/posts`} class="block hover:text-[var(--color-primary)]">{locale === 'zh' ? '动态' : 'Updates'}</a>
              <a href={`/${locale}/blog`} class="block hover:text-[var(--color-primary)]">{locale === 'zh' ? '文章' : 'Articles'}</a>
              <a href={`/${locale}/services`} class="block hover:text-[var(--color-primary)]">{locale === 'zh' ? '服务' : 'Services'}</a>
              <a href={`/${locale}/about`} class="block hover:text-[var(--color-primary)]">{locale === 'zh' ? '关于' : 'About'}</a>
            </div>
          </div>

          <!-- Contact (GEO) -->
          <div>
            <div class="font-medium mb-3">{locale === 'zh' ? '联系我们' : 'Contact'}</div>
            <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
              <div>{locale === 'zh' ? '微信' : 'WeChat'}: <span class="text-[var(--color-text)]">zenithjoyai</span></div>
              <div>{locale === 'zh' ? '抖音' : 'Douyin'}: <span class="text-[var(--color-text)]">zenithjoyai</span></div>
              <div>{locale === 'zh' ? '邮箱' : 'Email'}: <span class="text-[var(--color-text)]">zenithjoycloud@gmail.com</span></div>
            </div>
          </div>
        </div>

        <!-- Copyright -->
        <div class="pt-8 border-t border-[var(--color-border)] text-center text-sm text-[var(--color-text-muted)]">
          <p>&copy; {new Date().getFullYear()} ZenithJoyAI. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle Script -->
    <script>
      document.getElementById('theme-toggle')?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    </script>
  </body>
</html>
