---
import Base from '../../../../layouts/Base.astro';
import { getPaginatedPosts, getAllPosts, POSTS_PER_PAGE } from '../../../../data/posts';

export async function getStaticPaths() {
  const allPosts = await getAllPosts('zh');
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: String(i + 1) },
  })).filter(p => p.params.page !== '1'); // 第一页使用 index.astro
}

const { page } = Astro.params;
const pageNum = parseInt(page || '1');
const { posts, totalPages, currentPage, totalPosts } = await getPaginatedPosts('zh', pageNum);

// 如果页码无效，重定向到第一页
if (pageNum < 1 || pageNum > totalPages) {
  return Astro.redirect('/zh/blog');
}
---

<Base
  title={`博客 - 第 ${currentPage} 页 | AI 创作实战教程`}
  description="AI 自媒体培训博客，分享 AI 工具使用技巧、自动化工作流、内容创作方法论。帮助创作者用 AI 提升 10 倍效率。"
>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <!-- Header -->
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">博客</h1>
      <p class="text-xl text-[var(--color-text-muted)]">
        AI 创作实战教程，助你提升 10 倍效率
      </p>
    </header>

    <!-- Posts List -->
    <div class="divide-y divide-[var(--color-border)]">
      {posts.map(post => (
        <article class="group py-6 first:pt-0">
          <a href={`/zh/blog/${post.slug}`} class="flex gap-6 items-start">
            <div class="flex-1 min-w-0">
              <h2 class="text-lg md:text-xl font-bold mb-2 text-[var(--color-primary)] group-hover:opacity-80 transition-opacity">
                {post.title}
              </h2>
              <p class="text-[var(--color-text-muted)] line-clamp-2 mb-3 text-sm">
                {post.description || post.content?.slice(0, 120)}
              </p>
              <div class="flex items-center gap-4 text-xs text-[var(--color-text-muted)]">
                <span>{post.publishDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric' })}</span>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Pagination -->
    {totalPages > 1 && (
      <nav class="mt-12 flex justify-center items-center gap-2">
        {currentPage > 1 && (
          <a
            href={currentPage === 2 ? '/zh/blog' : `/zh/blog/page/${currentPage - 1}`}
            class="px-4 py-2 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-bg-card)] transition-colors"
          >
            ← 上一页
          </a>
        )}

        <div class="flex items-center gap-1">
          {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
            <a
              href={page === 1 ? '/zh/blog' : `/zh/blog/page/${page}`}
              class={`w-10 h-10 flex items-center justify-center rounded-lg transition-colors ${
                page === currentPage
                  ? 'bg-[var(--color-primary)] text-white'
                  : 'border border-[var(--color-border)] hover:bg-[var(--color-bg-card)]'
              }`}
            >
              {page}
            </a>
          ))}
        </div>

        {currentPage < totalPages && (
          <a
            href={`/zh/blog/page/${currentPage + 1}`}
            class="px-4 py-2 rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-bg-card)] transition-colors"
          >
            下一页 →
          </a>
        )}
      </nav>
    )}

    <!-- Post Count -->
    <div class="mt-6 text-center text-sm text-[var(--color-text-muted)]">
      第 {currentPage} / {totalPages} 页，共 {totalPosts} 篇文章
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center p-8 bg-gradient-to-br from-[var(--color-primary)]/5 to-[var(--color-accent)]/5 rounded-xl border border-[var(--color-border)]">
      <a href="/zh" class="text-[var(--color-primary)] hover:underline">
        返回首页 →
      </a>
    </div>
  </section>
</Base>
