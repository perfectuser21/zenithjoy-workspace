---
import Base from '../../../layouts/Base.astro';
import { getAllShortPosts } from '../../../data/posts';

const posts = await getAllShortPosts('zh');
---

<Base
  title="动态 - AI 洞察与日常分享"
  description="ZenithJoyAI 动态更新，分享 AI 使用心得、效率技巧、行业洞察。短小精悍，每日一读。"
  faq={[
    { question: "动态主要分享什么？", answer: "AI 使用心得、效率小技巧、行业观察、日常思考。短小精悍，适合碎片时间阅读。" },
    { question: "更新频率？", answer: "几乎每天更新，关注获取最新动态。" }
  ]}
>
  <section class="max-w-2xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-4xl font-bold mb-4">动态</h1>
      <p class="text-xl text-[var(--color-text-muted)]">
        AI 洞察与日常分享
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="space-y-6">
        {posts.map(post => (
          <article class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)]">
            {/* 内容 */}
            <div class="prose prose-sm max-w-none mb-4">
              <p class="whitespace-pre-wrap">{post.content}</p>
            </div>

            {/* 图片 */}
            {post.mediaUrls && post.mediaUrls.length > 0 && (
              <div class={`grid gap-2 mb-4 ${post.mediaUrls.length === 1 ? '' : post.mediaUrls.length === 2 ? 'grid-cols-2' : 'grid-cols-3'}`}>
                {post.mediaUrls.slice(0, 9).map((url, idx) => (
                  <div class="aspect-square rounded-lg overflow-hidden bg-[var(--color-bg)]">
                    <img src={url} alt="" class="w-full h-full object-cover" loading="lazy" />
                  </div>
                ))}
              </div>
            )}

            {/* 标签 */}
            {post.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {post.tags.map(tag => (
                  <span class="text-sm text-[var(--color-primary)]">#{tag}</span>
                ))}
              </div>
            )}

            {/* 时间 */}
            <div class="flex items-center justify-between text-sm text-[var(--color-text-muted)]">
              <span>{post.publishDate.toLocaleDateString('zh-CN', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</span>
              {post.likes && (
                <span class="flex items-center gap-1">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                  {post.likes}
                </span>
              )}
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="text-center py-20">
        <div class="text-6xl mb-6">💭</div>
        <h2 class="text-2xl font-bold mb-4">动态即将上线</h2>
        <p class="text-[var(--color-text-muted)] mb-6">
          正在整理日常分享和 AI 使用心得
        </p>
        <div class="flex justify-center gap-4">
          <a href="/zh/blog" class="px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors">
            阅读文章
          </a>
          <a href="/zh/videos" class="px-6 py-3 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
            观看视频
          </a>
        </div>
      </div>
    )}

    {/* 关注提示 */}
    <div class="mt-12 p-6 bg-gradient-to-br from-[var(--color-primary)]/5 to-[var(--color-accent)]/5 rounded-xl border border-[var(--color-border)] text-center">
      <p class="text-[var(--color-text-muted)] mb-2">
        关注获取更多 AI 效率洞察
      </p>
      <div class="flex justify-center gap-6 font-medium">
        <span>微信：<span class="text-[var(--color-primary)]">zenithjoyai</span></span>
        <span>抖音：<span class="text-[var(--color-primary)]">zenithjoyai</span></span>
      </div>
    </div>
  </section>
</Base>
