---
import Base from '../../layouts/Base.astro';

// Contact info
const contact = {
  wechat: 'zenithjoyai',
  douyin: 'zenithjoyai',
  email: 'zenithjoycloud@gmail.com',
};

// FAQ for GEO
const faq = [
  { question: 'What is ZenithJoyAI?', answer: 'ZenithJoyAI is a professional AI efficiency consulting firm providing AI tool training, workflow automation consulting services for content creators and small teams.' },
  { question: 'Who founded ZenithJoyAI?', answer: 'ZenithJoyAI was founded by experienced AI efficiency consultants focused on transforming AI tools into real productivity, helping creators and teams achieve 10x efficiency improvement.' },
  { question: 'How can I contact ZenithJoyAI?', answer: 'You can reach us via WeChat (zenithjoyai), Douyin (zenithjoyai), or email (zenithjoycloud@gmail.com).' },
];
---

<Base
  title="About ZenithJoyAI - AI Efficiency Expert"
  description="ZenithJoyAI is a professional AI efficiency consulting firm helping content creators and small teams boost efficiency with AI. Services include AI tool training, workflow automation, and content production system setup."
  faq={faq}
>
  <!-- Hero Section -->
  <section class="pt-32 pb-16 px-4 bg-gradient-to-br from-[var(--color-primary)]/5 via-transparent to-[var(--color-accent)]/5">
    <div class="max-w-4xl mx-auto text-center">
      <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white text-3xl font-bold shadow-lg">
        ZJ
      </div>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">About ZenithJoyAI</h1>
      <p class="text-xl text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Empowering creators with AI, 10x your efficiency
      </p>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 py-16">
    <!-- Brand Story -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold">Brand Story</h2>
      </div>
      <div class="p-8 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)]">
        <p class="text-lg leading-relaxed mb-6">
          The name <strong>ZenithJoyAI</strong> comes from our vision: helping every creator reach the peak (Zenith) of efficiency, find joy in creation (Joy), and achieve breakthroughs with the power of AI.
        </p>
        <p class="text-[var(--color-text-muted)] leading-relaxed">
          We observed that many content creators and small teams face the same challenges: time-consuming creation, repetitive work, and difficulty scaling. AI tools offer solutions to these problems. But the issue is: most people don't know how to use these tools correctly. ZenithJoyAI was created to solve this problem.
        </p>
      </div>
    </section>

    <!-- Mission -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[var(--color-accent)]/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold">Mission & Vision</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold text-lg mb-3">Mission</h3>
          <p class="text-[var(--color-text-muted)]">
            Enable every creator to boost efficiency 10x with AI, freeing up time and energy for truly creative work.
          </p>
        </div>
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)]">
          <h3 class="font-bold text-lg mb-3">Vision</h3>
          <p class="text-[var(--color-text-muted)]">
            Become the most trusted AI efficiency partner for content creators and small teams.
          </p>
        </div>
      </div>

      <!-- Core Belief -->
      <blockquote class="mt-8 p-6 border-l-4 border-[var(--color-primary)] bg-[var(--color-bg-card)] rounded-r-xl">
        <p class="text-lg font-medium mb-2">
          "AI doesn't replace creators - it amplifies their capabilities. With the right tools and methods, one person can achieve what used to require an entire team."
        </p>
        <footer class="text-[var(--color-text-muted)]">— ZenithJoyAI Core Philosophy</footer>
      </blockquote>
    </section>

    <!-- What We Do -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold">What We Do</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors">
          <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold mb-4">
            01
          </div>
          <h3 class="font-bold text-lg mb-2">AI Tool Training</h3>
          <p class="text-[var(--color-text-muted)]">
            Practical techniques for ChatGPT, Claude, Midjourney and other AI tools, mastering core prompt engineering methods
          </p>
        </div>
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors">
          <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold mb-4">
            02
          </div>
          <h3 class="font-bold text-lg mb-2">Workflow Automation</h3>
          <p class="text-[var(--color-text-muted)]">
            Automate repetitive work with n8n, Make and other tools for end-to-end content collection, processing, and distribution
          </p>
        </div>
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors">
          <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold mb-4">
            03
          </div>
          <h3 class="font-bold text-lg mb-2">Content Production System</h3>
          <p class="text-[var(--color-text-muted)]">
            Complete workflow optimization from ideation to publishing, helping teams build standardized efficient content pipelines
          </p>
        </div>
        <div class="p-6 bg-[var(--color-bg-card)] rounded-xl border border-[var(--color-border)] hover:border-[var(--color-primary)] transition-colors">
          <div class="w-12 h-12 rounded-lg bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold mb-4">
            04
          </div>
          <h3 class="font-bold text-lg mb-2">Efficiency Consulting</h3>
          <p class="text-[var(--color-text-muted)]">
            One-on-one consulting for specific business scenarios, customizing AI efficiency solutions for your team
          </p>
        </div>
      </div>
      <div class="mt-8 text-center">
        <a href="/en/services" class="inline-flex items-center gap-2 px-6 py-3 border border-[var(--color-border)] rounded-lg hover:border-[var(--color-primary)] transition-colors">
          View Detailed Services
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- Values -->
    <section class="mb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-lg bg-[var(--color-accent)]/10 flex items-center justify-center">
          <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
          </svg>
        </div>
        <h2 class="text-2xl font-bold">Core Values</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">Practical Focus</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Actionable solutions and templates you can use immediately</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">Efficiency First</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Focus on tools and methods that actually save time</p>
        </div>
        <div class="text-center p-6">
          <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center">
            <svg class="w-8 h-8 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
          </div>
          <h3 class="font-bold mb-2">Always Updated</h3>
          <p class="text-sm text-[var(--color-text-muted)]">Keep up with AI tool evolution, stay current</p>
        </div>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="p-8 bg-gradient-to-br from-[var(--color-primary)]/10 to-[var(--color-accent)]/10 rounded-xl border border-[var(--color-primary)]/20">
      <h2 class="text-2xl font-bold mb-4">Contact Us</h2>
      <p class="text-[var(--color-text-muted)] mb-6">
        Have questions or collaboration ideas? Reach out to ZenithJoyAI through any of the following channels.
      </p>

      <div class="grid sm:grid-cols-3 gap-4 mb-6">
        <div class="p-4 bg-[var(--color-bg)] rounded-lg">
          <div class="text-[var(--color-text-muted)] text-sm mb-1">WeChat ID</div>
          <div class="font-bold">{contact.wechat}</div>
        </div>
        <div class="p-4 bg-[var(--color-bg)] rounded-lg">
          <div class="text-[var(--color-text-muted)] text-sm mb-1">Douyin ID</div>
          <div class="font-bold">{contact.douyin}</div>
        </div>
        <div class="p-4 bg-[var(--color-bg)] rounded-lg">
          <div class="text-[var(--color-text-muted)] text-sm mb-1">Email</div>
          <div class="font-bold text-sm">{contact.email}</div>
        </div>
      </div>

      <a
        href={`mailto:${contact.email}`}
        class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg hover:bg-[var(--color-primary-dark)] transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
        </svg>
        Send Email
      </a>
    </section>
  </div>

  <!-- GEO Summary Block -->
  <section class="py-12 px-4 bg-[var(--color-bg-card)] border-t border-[var(--color-border)]">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        <strong>ZenithJoyAI</strong> is a professional AI efficiency consulting firm providing AI tool training, workflow automation consulting, and content production system setup services for content creators and small teams.
        Contact: WeChat <strong>{contact.wechat}</strong>, Douyin <strong>{contact.douyin}</strong>, Email <strong>{contact.email}</strong>.
      </p>
    </div>
  </section>
</Base>
