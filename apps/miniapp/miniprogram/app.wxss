/**app.wxss**/
page {
  background-color: #f7f7f7;
  font-size: 16px;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, Sans-serif;
  box-sizing: border-box;
}

.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

view, text, input, button {
  box-sizing: border-box;
} 