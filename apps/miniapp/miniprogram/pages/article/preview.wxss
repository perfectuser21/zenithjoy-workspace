/* pages/article/preview.wxss */
.container {
  padding: 30rpx;
}

.article-header {
  margin-bottom: 30rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.article-meta {
  display: flex;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.article-author {
  margin-right: 20rpx;
}

.article-tags {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: #576b95;
  background-color: #f0f9ff;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  margin-right: 16rpx;
  margin-bottom: 10rpx;
}

.article-cover {
  margin-bottom: 30rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.article-cover image {
  width: 100%;
  border-radius: 12rpx;
}

.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 40rpx;
  text-align: justify;
}

.article-stats {
  display: flex;
  margin-bottom: 40rpx;
}

.stat-item {
  display: flex;
  align-items: center;
  margin-right: 40rpx;
}

.stat-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.stat-text {
  font-size: 26rpx;
  color: #999;
}

.preview-tips {
  text-align: center;
  font-size: 26rpx;
  color: #ff9500;
  background-color: #fff9f0;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: white;
  text-align: center;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.loading-container {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
}

.loading {
  font-size: 28rpx;
  color: #999;
} 