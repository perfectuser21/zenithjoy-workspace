<!--pages/article/preview.wxml-->
<view class="container" wx:if="{{!isLoading && article}}">
  <view class="article-header">
    <view class="article-title">{{article.title}}</view>
    <view class="article-meta">
      <text class="article-author">{{article.author}}</text>
      <text class="article-date">{{article.date}}</text>
    </view>
    <view class="article-tags">
      <text class="tag" wx:for="{{article.tags}}" wx:key="*this">{{item}}</text>
    </view>
  </view>
  
  <view class="article-cover">
    <image src="{{article.cover}}" mode="widthFix" bindtap="previewImage" data-src="{{article.cover}}"></image>
  </view>
  
  <view class="article-content">
    <text user-select>{{article.content}}</text>
  </view>
  
  <view class="article-stats">
    <view class="stat-item">
      <view class="stat-icon">👁️</view>
      <view class="stat-text">浏览 {{article.views || 0}}</view>
    </view>
    <view class="stat-item">
      <view class="stat-icon">👍</view>
      <view class="stat-text">点赞 {{article.likes || 0}}</view>
    </view>
  </view>
  
  <view class="preview-tips">这是预览效果，尚未发布</view>
  
  <view class="action-btn" bindtap="goBack">返回编辑</view>
</view>

<view class="loading-container" wx:else>
  <view class="loading">加载中...</view>
</view> 