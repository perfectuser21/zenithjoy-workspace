<view class="container">
  <view class="header">
    <view class="title">
      <text>AI 助手</text>
      <text class="subtitle">{{selectedBot ? selectedBot.name : '默认助手'}}</text>
    </view>
    <view class="header-actions">
      <!-- 切换流式响应模式按钮 -->
      <view class="action-btn" bindtap="toggleStreamMode">
        <image src="../../images/{{useStreamMode ? 'streaming.png' : 'polling.png'}}" class="icon"></image>
        <text class="btn-text">{{useStreamMode ? '流式' : '轮询'}}</text>
      </view>
      <!-- 切换机器人按钮 -->
      <view class="action-btn" bindtap="openSwitchBotModal">
        <image src="../../images/bot.png" class="icon"></image>
        <text class="btn-text">切换</text>
      </view>
      <!-- 设置按钮 -->
      <view class="action-btn" bindtap="openApiSettings">
        <image src="../../images/settings.png" class="icon"></image>
        <text class="btn-text">设置</text>
      </view>
      <!-- 清空历史按钮 -->
      <view class="action-btn" bindtap="clearHistory">
        <image src="../../images/clear.png" class="icon"></image>
        <text class="btn-text">清空</text>
      </view>
    </view>
  </view>
  
  <!-- API设置面板 -->
  <view class="settings-panel" wx:if="{{showSettings}}">
    <view class="settings-title">API配置</view>
    <view class="api-status-message">
      <text class="status-text">✅ API密钥已自动配置完成</text>
    </view>
    <view class="form-item">
      <text class="label">API密钥</text>
      <input 
        class="input" 
        placeholder="输入Coze API密钥..." 
        value="{{apiKey}}"
        bindinput="inputApiKey"
      />
    </view>
    <view class="form-item">
      <text class="label">Bot ID</text>
      <input 
        class="input" 
        placeholder="输入Coze Bot ID..." 
        value="{{botId}}"
        bindinput="inputBotId"
      />
    </view>
    <view class="button-row">
      <button bindtap="saveSettings" class="save-btn">保存</button>
      <button bindtap="toggleSettings" class="cancel-btn">取消</button>
    </view>
    <view class="settings-hint">
      <text>无需手动配置，系统已设置默认API</text>
    </view>
  </view>
  
  <view class="chat-container">
    <scroll-view scroll-y class="chat-messages" scroll-top="{{scrollTop}}">
      <block wx:if="{{history.length > 0}}">
        <view class="message-item" wx:for="{{history}}" wx:key="index">
          <view class="user-message">
            <text class="message-text">{{item.query}}</text>
          </view>
          <view class="ai-message">
            <text class="message-text">{{item.response}}</text>
            <view class="message-actions">
              <text class="action-btn" bindtap="copyResponse" data-index="{{index}}">复制</text>
            </view>
          </view>
        </view>
      </block>
      <view wx:else class="empty-hint">
        <text>开始与AI助手对话吧</text>
      </view>
    </scroll-view>
    
    <!-- 错误信息展示区域 -->
    <view class="error-info-container" wx:if="{{errorInfo}}">
      <view class="error-info-title">处理状态</view>
      <view class="ai-processing-container" wx:if="{{isLoading && errorInfo.indexOf('AI正在思考') >= 0}}">
        <view class="ai-thinking-animation">
          <text>AI正在思考</text>
          <text class="dot-animation">...</text>
        </view>
        <view class="progress-bar-container">
          <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
          <view class="progress-text">{{progressPercent}}%</view>
        </view>
        <view class="estimated-time">{{estimatedTime}}</view>
      </view>
      <text class="error-info" selectable="true">{{errorInfo}}</text>
      <view class="error-actions" wx:if="{{errorInfo && !isLoading}}">
        <button class="copy-btn" size="mini" bindtap="copyError">复制详情</button>
      </view>
    </view>
    
    <!-- 处理中状态提示 -->
    <view class="processing-indicator" wx:if="{{isLoading}}">
      <view class="processing-spinner"></view>
      <text class="processing-text">AI正在思考中，请稍候...</text>
      <text class="processing-tip" wx:if="{{errorInfo && errorInfo.indexOf('处理中') > -1}}">消息将持续轮询直到收到回复</text>
      
      <!-- 添加进度条 -->
      <block wx:if="{{progressPercent > 0}}">
        <view class="progress-info">
          <text class="progress-text">{{progressPercent}}%</text>
        </view>
        <view class="progress-bar-container">
          <view class="progress-bar" style="width: {{progressPercent}}%;"></view>
        </view>
      </block>
    </view>
    
    <view class="input-container">
      <input 
        class="query-input" 
        placeholder="请输入您的问题..." 
        value="{{query}}"
        bindinput="inputQuery"
        confirm-type="send"
        bindconfirm="sendQuery"
      />
      <button 
        class="send-button {{isLoading ? 'loading' : ''}}" 
        bindtap="sendQuery" 
        disabled="{{isLoading}}"
      >
        <text wx:if="{{!isLoading}}">发送</text>
        <view wx:else class="loading-icon"></view>
      </button>
    </view>
  </view>
  
  <view class="footer">
    <button bindtap="clearHistory" class="clear-btn">清空记录</button>
    <button bindtap="testAPIV3" class="test-btn primary">测试V3 API ✓</button>
    <button bindtap="testAPI" class="test-btn secondary">测试V2 API</button>
  </view>
  
  <!-- 切换机器人模态框 -->
  <view class="modal" wx:if="{{switchBotModalVisible}}">
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">选择AI助手</text>
        <view class="modal-close" bindtap="closeSwitchBotModal">×</view>
      </view>
      <view class="modal-body">
        <view class="bot-list">
          <view wx:for="{{chatBots}}" wx:key="index" class="bot-item {{selectedBot && selectedBot.botId === item.botId ? 'selected' : ''}}" bindtap="selectBot" data-index="{{index}}">
            <text class="bot-name">{{item.name}}</text>
            <text class="bot-description">{{item.description}}</text>
          </view>
        </view>
        <!-- 无机器人提示 -->
        <view wx:if="{{!chatBots || chatBots.length === 0}}" class="empty-bots">
          <text>未配置机器人，请前往设置</text>
        </view>
      </view>
    </view>
  </view>
</view> 