/* pages/ai-features/index.wxss */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f8f9fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.header {
  padding: 15px;
  background-color: #007bff;
  color: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  z-index: 10;
}

.title {
  font-size: 18px;
  font-weight: bold;
  display: flex;
  flex-direction: column;
}

.subtitle {
  font-size: 12px;
  font-weight: normal;
  margin-top: 2px;
  opacity: 0.9;
}

.header-actions {
  display: flex;
  align-items: center;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-left: 10px;
  padding: 5px;
}

.icon {
  width: 20px;
  height: 20px;
}

.btn-text {
  font-size: 10px;
  margin-top: 2px;
}

.settings-icon {
  font-size: 40rpx;
  padding: 10rpx;
}

/* API设置面板 */
.settings-panel {
  background-color: white;
  padding: 30rpx;
  border-bottom: 1rpx solid #e0e0e0;
}

.settings-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #333;
}

/* API状态消息样式 */
.api-status-message {
  background-color: #f0fff0;
  border-radius: 8rpx;
  padding: 15rpx;
  margin-bottom: 20rpx;
  text-align: center;
  border: 1px solid #d0f0d0;
}

.status-text {
  color: #07c160;
  font-size: 28rpx;
}

.form-item {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  background-color: #f5f5f5;
  border-radius: 8rpx;
  padding: 15rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #e0e0e0;
}

.button-row {
  display: flex;
  justify-content: space-between;
  margin-top: 30rpx;
}

.save-btn, .cancel-btn {
  width: 48%;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.save-btn {
  background-color: #07c160;
  color: white;
}

.cancel-btn {
  background-color: #f5f5f5;
  color: #666;
}

.settings-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 20rpx;
}

.clear-btn {
  font-size: 24rpx;
  color: white;
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin: 0 10rpx;
}

.test-btn {
  font-size: 24rpx;
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin: 0 10rpx;
}

.test-btn.primary {
  background: #07c160;
  font-weight: bold;
}

.test-btn.secondary {
  background: #999;
}

.chat-container {
  flex: 1;
  padding: 10px;
  overflow-y: auto;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  margin-bottom: 20rpx;
}

.message-item {
  margin-bottom: 30rpx;
}

.user-message, .ai-message {
  max-width: 80%;
  border-radius: 10rpx;
  padding: 20rpx;
  word-wrap: break-word;
}

.user-message {
  background-color: #07c160;
  color: white;
  align-self: flex-end;
  margin-left: auto;
}

.ai-message {
  background-color: white;
  color: #333;
  margin-top: 10rpx;
  box-shadow: 0 2rpx 5rpx rgba(0,0,0,0.1);
}

.message-text {
  line-height: 1.5;
  font-size: 28rpx;
}

.message-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 15rpx;
}

.action-btn {
  font-size: 24rpx;
  color: #07c160;
  margin-left: 20rpx;
}

.empty-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 300rpx;
  color: #999;
  font-size: 28rpx;
}

.input-container {
  padding: 10px;
  background-color: white;
  border-top: 1px solid #dee2e6;
  display: flex;
  align-items: center;
}

.query-input {
  flex: 1;
  border: 1px solid #ced4da;
  border-radius: 20px;
  padding: 8px 15px;
  font-size: 14px;
  background-color: #f8f9fa;
}

.send-button {
  margin-left: 10px;
  width: 40px;
  height: 40px;
  border-radius: 20px;
  background-color: #007bff;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 0;
}

.send-button[disabled] {
  background-color: #6c757d;
  opacity: 0.5;
}

.send-icon {
  width: 20px;
  height: 20px;
}

.send-icon.loading {
  animation: spin 1.5s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.footer {
  padding: 20rpx;
  display: flex;
  justify-content: center;
}

/* 错误信息展示区域样式 */
.error-section {
  background-color: #fff3f3;
  border: 1rpx solid #ffcbcb;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* 处理中状态提示样式 */
.processing-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  margin-bottom: 20rpx;
  background-color: #f0f7ff;
  border-radius: 10rpx;
  border: 1rpx solid #d0e3ff;
}

.processing-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(7, 193, 96, 0.2);
  border-top: 6rpx solid #07c160;
  border-radius: 50%;
  animation: spin 1.5s linear infinite;
  margin-bottom: 10rpx;
}

.processing-text {
  font-size: 26rpx;
  color: #07c160;
}

.processing-tip {
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  text-align: center;
}

/* 进度条样式 */
.progress-info {
  margin-top: 15rpx;
  text-align: center;
}

.progress-text {
  font-size: 24rpx;
  color: #2b85e4;
  font-weight: bold;
}

.progress-bar-container {
  width: 90%;
  height: 10rpx;
  background-color: #e9eaec;
  border-radius: 10rpx;
  margin: 10rpx auto;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background-color: #2b85e4;
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.error-header {
  display: flex;
  justify-content: space-between;
  padding: 15rpx 20rpx;
  background-color: #ffebeb;
  border-bottom: 1rpx solid #ffcbcb;
}

.error-title {
  color: #e54d42;
  font-size: 26rpx;
  font-weight: bold;
}

.error-copy {
  color: #07c160;
  font-size: 26rpx;
}

.error-content {
  padding: 20rpx;
  max-height: 300rpx;
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
  white-space: pre-wrap;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 错误信息容器样式更新 */
.error-info-container {
  margin: 20rpx;
  border-radius: 10rpx;
  background-color: #f8f8f8;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.error-info-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.error-info {
  font-size: 24rpx;
  color: #666;
  word-break: break-all;
  white-space: pre-wrap;
  max-height: 300rpx;
  overflow-y: auto;
}

.error-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.copy-btn {
  background-color: #f0f0f0;
  color: #333;
  font-size: 24rpx;
}

/* AI处理中的动画和进度条 */
.ai-processing-container {
  margin-bottom: 20rpx;
  background-color: #f0f7ff;
  padding: 16rpx;
  border-radius: 8rpx;
  border-left: 4rpx solid #4285f4;
}

.ai-thinking-animation {
  font-size: 30rpx;
  font-weight: bold;
  color: #4285f4;
  margin-bottom: 12rpx;
}

.dot-animation {
  animation: dotAnimation 1.5s infinite;
}

@keyframes dotAnimation {
  0% { opacity: 0.3; }
  50% { opacity: 1; }
  100% { opacity: 0.3; }
}

.progress-bar-container {
  height: 24rpx;
  background-color: #e0e0e0;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  margin: 12rpx 0;
}

.progress-bar {
  height: 100%;
  background-color: #4285f4;
  border-radius: 12rpx;
  transition: width 0.5s ease;
}

.progress-text {
  position: absolute;
  top: 0;
  right: 10rpx;
  font-size: 18rpx;
  line-height: 24rpx;
  color: #fff;
  font-weight: bold;
  text-shadow: 0 0 2rpx rgba(0, 0, 0, 0.5);
}

.estimated-time {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

/* 聊天列表 */
.chat-list {
  display: flex;
  flex-direction: column;
}

/* 空历史记录提示 */
.empty-history {
  text-align: center;
  color: #6c757d;
  padding: 30px;
  font-size: 14px;
}

/* 聊天项目 */
.chat-item {
  display: flex;
  margin-bottom: 20px;
  max-width: 100%;
}

/* 用户聊天项目 */
.chat-item.user {
  flex-direction: row-reverse;
}

/* 头像 */
.avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

/* 用户头像 */
.user-avatar {
  margin-left: 10px;
}

/* AI头像 */
.ai-avatar {
  margin-right: 10px;
}

/* 消息样式 */
.message {
  padding: 10px 15px;
  border-radius: 18px;
  max-width: 70%;
  word-wrap: break-word;
  white-space: pre-wrap;
  font-size: 14px;
  display: flex;
  flex-direction: column;
}

/* 用户消息 */
.user-message {
  background-color: #007bff;
  color: white;
  border-top-right-radius: 4px;
}

/* AI消息 */
.ai-message {
  background-color: #e9ecef;
  color: #343a40;
  border-top-left-radius: 4px;
}

/* 流式响应中的消息 */
.ai-message.streaming {
  background-color: #f0f4f8;
  border: 1px solid #007bff;
  position: relative;
}

/* 流式指示器 */
.streaming-indicator {
  display: flex;
  margin-bottom: 8px;
}

.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #007bff;
  margin-right: 4px;
  animation: pulse 1.5s infinite;
}

.dot2 {
  animation-delay: 0.3s;
}

.dot3 {
  animation-delay: 0.6s;
}

@keyframes pulse {
  0% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.2); }
  100% { opacity: 0.4; transform: scale(1); }
}

/* 回退消息样式 */
.ai-message.fallback {
  background-color: #f8f9fa;
  border: 1px dashed #6c757d;
  color: #6c757d;
}

/* 错误消息样式 */
.ai-message.error {
  background-color: #f8d7da;
  color: #721c24;
  border: 1px solid #f5c6cb;
}

/* 消息文本 */
.message-text {
  line-height: 1.5;
  white-space: pre-wrap;
}

/* 消息时间 */
.message-time {
  font-size: 10px;
  color: rgba(0, 0, 0, 0.5);
  margin-top: 5px;
  align-self: flex-end;
}

.user-message .message-time {
  color: rgba(255, 255, 255, 0.7);
}

/* 消息底部 */
.message-footer {
  margin-top: 5px;
  padding-top: 5px;
  border-top: 1px dashed rgba(0, 0, 0, 0.1);
  font-size: 10px;
  color: #6c757d;
}

.message-info {
  display: block;
  margin-bottom: 2px;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

/* 模态框内容 */
.modal-content {
  width: 80%;
  max-width: 500px;
  background-color: white;
  border-radius: 10px;
  overflow: hidden;
  box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

/* 模态框头部 */
.modal-header {
  padding: 15px;
  border-bottom: 1px solid #dee2e6;
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #007bff;
  color: white;
}

/* 模态框标题 */
.modal-title {
  font-size: 16px;
  font-weight: bold;
}

/* 模态框关闭按钮 */
.modal-close {
  font-size: 24px;
  line-height: 1;
  cursor: pointer;
}

/* 模态框主体 */
.modal-body {
  padding: 15px;
  max-height: 60vh;
  overflow-y: auto;
}

/* 机器人列表 */
.bot-list {
  display: flex;
  flex-direction: column;
}

/* 机器人项目 */
.bot-item {
  padding: 12px;
  border-radius: 8px;
  margin-bottom: 10px;
  border: 1px solid #dee2e6;
  transition: all 0.2s ease;
}

/* 选中的机器人项目 */
.bot-item.selected {
  background-color: #e9f5ff;
  border-color: #007bff;
}

/* 机器人名称 */
.bot-name {
  font-size: 14px;
  font-weight: bold;
  display: block;
  margin-bottom: 5px;
}

/* 机器人描述 */
.bot-description {
  font-size: 12px;
  color: #6c757d;
  display: block;
}

/* 空机器人列表提示 */
.empty-bots {
  text-align: center;
  padding: 20px;
  color: #6c757d;
} 