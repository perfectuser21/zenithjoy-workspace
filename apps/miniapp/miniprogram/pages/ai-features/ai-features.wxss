/* pages/ai-features/ai-features.wxss */
.container {
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  background-color: #f6f7f9;
  min-height: 100vh;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #666;
}

.feature-list {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f0f0f0;
}

.ai-chat-icon {
  background-color: rgba(7, 193, 96, 0.1);
  position: relative;
}

.ai-chat-icon:after {
  content: "";
  position: absolute;
  top: 50%;
  left: 50%;
  width: 40rpx;
  height: 40rpx;
  background-color: #07C160;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.feature-content {
  flex: 1;
}

.feature-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
  display: block;
}

.feature-desc {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.feature-arrow {
  width: 16rpx;
  height: 16rpx;
  border-top: 2rpx solid #bbb;
  border-right: 2rpx solid #bbb;
  transform: rotate(45deg);
}

.tips {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tips-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.tips-item {
  display: flex;
  margin-bottom: 10rpx;
  align-items: flex-start;
}

.tips-dot {
  color: #07C160;
  margin-right: 10rpx;
  font-weight: bold;
}

.tips-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}