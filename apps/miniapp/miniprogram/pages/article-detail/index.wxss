/* pages/article-detail/index.wxss */
.container {
  padding: 30rpx;
}

.article-header {
  margin-bottom: 40rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.article-meta {
  display: flex;
  align-items: center;
}

.article-date {
  font-size: 26rpx;
  color: #999;
}

.article-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  margin-bottom: 40rpx;
  text-align: justify;
}

.action-buttons {
  display: flex;
  justify-content: center;
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.copy-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07C160;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
}

.loading {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666;
  font-size: 28rpx;
}

.empty-tip {
  width: 100%;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 30rpx;
} 