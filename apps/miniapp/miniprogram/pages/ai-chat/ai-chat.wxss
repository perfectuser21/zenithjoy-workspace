/* 聊天页面样式 */

.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f6f7f9;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 系统消息样式 */
.system-messages {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.system-message {
  margin: 6rpx 0;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  max-width: 90%;
  text-align: center;
  animation: fadeIn 0.3s ease-in, fadeOut 0.3s ease-out 4.7s forwards;
}

.system-message-info {
  background-color: rgba(7, 193, 96, 0.8);
  color: white;
}

.system-message-success {
  background-color: rgba(52, 199, 89, 0.8);
  color: white;
}

.system-message-warning {
  background-color: rgba(255, 149, 0, 0.8);
  color: white;
}

.system-message-error {
  background-color: rgba(255, 59, 48, 0.8);
  color: white;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes fadeOut {
  from { opacity: 1; }
  to { opacity: 0; }
}

/* 消息列表样式 */
.messages-container {
  flex: 1;
  overflow-y: auto;
  padding: 30rpx 30rpx 120rpx;
  margin-bottom: 120rpx;
}

.message-item {
  max-width: 80%;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  animation: fadeInLeft 0.3s ease-out;
}

@keyframes fadeInLeft {
  from { 
    opacity: 0; 
    transform: translateX(-20rpx);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

.user-message {
  align-self: flex-end;
  margin-left: auto;
  animation: fadeInRight 0.3s ease-out;
}

@keyframes fadeInRight {
  from { 
    opacity: 0; 
    transform: translateX(20rpx);
  }
  to { 
    opacity: 1; 
    transform: translateX(0);
  }
}

.assistant-message {
  align-self: flex-start;
  margin-right: auto;
}

.message-content {
  padding: 20rpx 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
  position: relative;
}

.user-message .message-content {
  background-color: #07C160;
  color: white;
  border-top-right-radius: 4rpx;
}

.assistant-message .message-content {
  background-color: white;
  color: #333333;
  border-top-left-radius: 4rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.error-message .message-content {
  background-color: #ffebee;
  color: #d32f2f;
}

.message-time {
  font-size: 20rpx;
  color: #999999;
  margin-top: 6rpx;
  align-self: flex-end;
}

/* 加载动画 */
.loading-dots {
  display: inline-flex;
  margin-right: 10rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  background-color: #999;
  border-radius: 50%;
  margin: 0 3rpx;
  display: inline-block;
  animation: dot-flashing 1s infinite alternate;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes dot-flashing {
  0% { opacity: 0.3; }
  100% { opacity: 1; }
}

/* 输入框样式 */
.input-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background-color: white;
  border-top: 1rpx solid #e5e5e5;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 10;
}

.message-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #333;
}

.send-button {
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-left: 20rpx;
  background-color: #07C160;
  color: white;
  border-radius: 36rpx;
  font-size: 28rpx;
  padding: 0;
}

.send-button-disabled {
  background-color: rgba(7, 193, 96, 0.5);
}

/* 功能按钮区域 - 移除 */
.action-buttons {
  display: none;
}

/* 图片样式 */
.message-images {
  margin-top: 16rpx;
  width: 100%;
}

.image-gallery {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.content-image {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 10rpx;
  border-radius: 8rpx;
  background-color: #f0f0f0;
}

.single-image .content-image {
  width: 100%;
  max-height: 400rpx;
}

/* 分段消息样式 */
.assistant-message + .assistant-message {
  margin-top: 12rpx;
}

/* 标题消息特殊样式 */
.assistant-message .message-content strong,
.assistant-message .message-content .title-text {
  font-weight: bold;
  color: #07C160;
}

/* 图片容器呼吸动画 */
@keyframes pulse {
  0% {
    box-shadow: 0 0 0 0 rgba(7, 193, 96, 0.1);
  }
  70% {
    box-shadow: 0 0 0 6rpx rgba(7, 193, 96, 0);
  }
  100% {
    box-shadow: 0 0 0 0 rgba(7, 193, 96, 0);
  }
} 