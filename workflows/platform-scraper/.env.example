# Platform Scraper 环境变量
# 复制为 .env 并填入实际值

# Windows Runner（call_runner.sh）
RUNNER_API_KEY=your-runner-api-key-here
WINDOWS_IP=100.x.x.x
RUNNER_PORT=3000

# VNC 容器（platform_login.sh）
VNC_PASSWORD=your-vnc-password
VPS_IP=your-vps-ip

# VPS Publisher（vps_publisher.js）
DASHBOARD_API=http://localhost:3333
FILE_RECEIVER_PORT=3001

# 爸爸公司 Scraper（vps_scraper_dad.js）
WINDOWS_IP_DAD=100.x.x.x

# Scrape & Sync（scrape_and_sync.sh）
VPS_SCRAPER_PATH=/home/xx/vps_scraper.js
