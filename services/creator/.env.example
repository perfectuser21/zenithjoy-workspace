# ZenithJoy Creator 服务环境变量
#
# 使用方式：cp .env.example .env 并按需填写
# 生产环境变量由 launchd plist 提供（com.zenithjoy.creator-api.plist）

# ─── apps/api 上游（PR-b：creator-api 把 /api/topics 转发到这里）
APPS_API_BASE=http://localhost:5200

# ─── ZenithJoy 内部 API Token（用于 creator-api -> apps/api 鉴权）
# 生成：openssl rand -hex 32
# 本地开发双写：~/.credentials/zenithjoy-internal-token
# 1Password：CS Vault → "ZenithJoy Internal API Token"
# 留空 = apps/api 以 dev 友好模式放行
ZENITHJOY_INTERNAL_TOKEN=

# ─── 老变量：pipeline 派发入口（server.py 的 /api/pipelines 兼容转发）
# PR-b 把默认值从 3001 改为 5200，统一到 apps/api
CREATOR_PIPELINE_API=http://localhost:5200

# ─── Notion 代理（由 creator-api 独占，不要移到 apps/api）
# NOTION_API_KEY=secret_xxx
